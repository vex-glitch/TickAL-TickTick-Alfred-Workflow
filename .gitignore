# Personal config — copy from *.example.py and fill in your own
filters_config.py
tags_config.py

# Alfred workflow package (distributed via Releases, not committed)
*.alfredworkflow

# Python
__pycache__/
*.py[cod]
*.so

# Bundled lib — skip package metadata and binaries, keep the actual packages
src/lib/*.dist-info/
src/lib/bin/

# macOS
.DS_Store

# Claude Code
.claude/

# Credentials (stored in ~/.ticktick_alfred/config.json, never here)
config.json

# Local debug captures & config backups (not part of the workflow)
Alfred Debuger*.txt
Karabiner Event Viewer*.json
*.backup.py
local.mk

# maintainer-only, never public
/CLAUDE.md
/HANDOFF.md
/RESTRUCTURE_PLAN.md
/tools/
/docs/forum/
